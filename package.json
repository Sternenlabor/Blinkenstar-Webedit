        "@mui/system": "^9.0.0",
        "i18next": "^26.0.4",
        "immutable": "^5.1.5",
        "ios-safe-audio-context": "^1.0.1",
        "lodash": "^4.18.1",
        "prop-types": "^15.8.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-i18next": "^17.0.2",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.14.0",
        "redux": "^5.0.1",
        "redux-actions": "3.0.3",
        "redux-promise": "^0.6.0",
        "uuid-js": "^0.7.5",
        "waud.js": "^1.0.3"
    },
    "resolutions": {
