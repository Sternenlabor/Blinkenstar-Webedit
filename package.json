{
    "name": "webedit-react",
    "version": "1.0.3",
    "description": "Webeditor for Blinkenstar",
    "scripts": {
        "test": "npm run build && npm run lint && npm run typecheck && npm run test:unit",
        "test:unit": "node --test webpack.config.test.js db.test.js config.test.js editorSpacing.test.js animationNormalization.test.js animationJsonTransfer.test.js animationInMenuActions.test.js flashAudioContexts.test.js menuAnimationOrder.test.js modemOrder.test.js rightMenu.github.test.js",
        "start": "cross-env NODE_ENV=development API_URL=http://localhost:8000 webpack-dev-server --host 0.0.0.0 --hot --progress --history-api-fallback",
        "dev:frontend": "npm run dev",
        "dev": "cross-env NODE_ENV=development API_URL=http://localhost:8000 webpack-dev-server --host 0.0.0.0 --history-api-fallback",
        "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
        "build": "node scripts/clean-public.js && cross-env NODE_ENV=production API_URL=/api webpack",
        "typecheck": "tsc --noEmit",
        "backend": "php -S localhost:8000 -t src/api",
        "dev:all": "concurrently \"npm run dev\" \"npm run backend\""
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Sternenlabor/Blinkenstar-Webedit.git"
    },
    "author": "marudor",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/Sternenlabor/Blinkenstar-Webedit/issues"
    },
    "homepage": "https://github.com/Sternenlabor/Blinkenstar-Webedit#readme",
    "engines": {
        "node": ">=20.17.0",
        "yarn": ">=1.22.22"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/core": "^7.29.0",
        "@babel/eslint-parser": "^7.28.6",
        "@babel/plugin-proposal-decorators": "^7.29.0",
        "@babel/preset-env": "^7.29.2",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@types/lodash": "^4.17.24",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/redux-actions": "^2.6.5",
        "@types/uuid-js": "^0.7.6",
        "babel-loader": "^10.1.1",
        "concurrently": "^9.2.1",
        "copy-webpack-plugin": "^14.0.0",
        "core-js": "^3.49.0",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "dotenv": "^17.4.1",
        "eslint": "^9.39.4",
        "favicons": "^7.2.0",
        "favicons-webpack-plugin": "^6.0.1",
        "html-webpack-plugin": "^5.6.6",
        "prettier": "^3.8.2",
        "style-loader": "^4.0.0",
        "svg-inline-loader": "^0.8.2",
        "typescript": "^6.0.2",
        "webpack": "^5.106.1",
        "webpack-cli": "^7.0.2",
        "webpack-dev-server": "^5.2.3"
